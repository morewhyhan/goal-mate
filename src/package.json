{
  "name": "goal-mate",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name goal_mate_v01",
    "db:reset": "prisma migrate reset --force --skip-seed",
    "db:seed": "node scripts/seed-goal-mate.mjs",
    "typecheck": "tsc --noEmit",
    "verify:v01": "pnpm db:generate && pnpm typecheck",
    "verify:v01:api": "node scripts/verify-v01-acceptance.mjs",
    "verify:v01:api:write": "node scripts/verify-v01-acceptance.mjs --write",
    "verify:v01:api:auth": "node scripts/verify-v01-acceptance.mjs --require-auth",
    "verify:v01:api:auth:write": "node scripts/verify-v01-acceptance.mjs --require-auth --write",
    "verify:v01:prepare-auth": "node scripts/prepare-v01-auth-session.mjs",
    "verify:v01:business": "node scripts/verify-v01-business-flow.mjs",
    "verify:v01:business:write": "node scripts/verify-v01-business-flow.mjs --write",
    "verify:agent-loop": "node scripts/verify-agent-action-loop.mjs",
    "verify:agent-loop:write": "node scripts/verify-agent-action-loop.mjs --write",
    "verify:deployment-config": "node scripts/verify-deployment-config.mjs",
    "verify:deployment-config:write": "node scripts/verify-deployment-config.mjs --write",
    "verify:secrets": "node scripts/verify-secret-hygiene.mjs",
    "verify:static": "pnpm verify:secrets && pnpm verify:deployment-config",
    "deploy:bundle": "node scripts/create-deploy-bundle.mjs",
    "worker:qq": "node scripts/qq-bot-worker.mjs",
    "worker:scheduler": "node scripts/scheduler-worker.mjs",
    "worker:scheduler:once": "node scripts/scheduler-worker.mjs --once --force-reminder=morning_planning"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.4.1",
    "@hono/zod-openapi": "^1.2.4",
    "@hono/zod-validator": "^0.7.6",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.0.0",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@tanstack/react-query": "^5.56.2",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "hono": "^4.6.2",
    "ky": "^1.7.2",
    "lucide-react": "^1.7.0",
    "next": "14.2.5",
    "next-themes": "^0.4.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.72.0",
    "recharts": "2.15.4",
    "sonner": "^1.5.0",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "18.11.18",
    "@types/react": "18.0.26",
    "@types/react-dom": "18.0.10",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "prisma": "^6.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5"
  },
  "packageManager": "pnpm@9.11.0"
}
