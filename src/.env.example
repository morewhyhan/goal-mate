# Minimum required on a single server.
DATABASE_URL="file:./goal-mate.db"
NEXT_PUBLIC_APP_URL="http://your-server-ip:3000"
GOAL_MATE_SECRET="replace-with-long-random-local-secret"

# Defaults. Usually do not change these in v0.1.
PORT="3000"
HOSTNAME="0.0.0.0"
GOAL_MATE_MODEL_PROVIDER="B.AI"
GOAL_MATE_MODEL_API_BASE="https://api.b.ai"
GOAL_MATE_MODEL="gpt-5-nano"
GOAL_MATE_REASONING_MODEL=""
QQ_BOT_API_BASE="https://api.sgroup.qq.com"
QQ_BOT_INTENTS="33554432"
SCHEDULER_TICK_SECONDS="60"
SCHEDULER_TIMEZONE="Asia/Shanghai"
SCHEDULER_MORNING_TIME="08:30"
SCHEDULER_MIDDAY_TIME="12:30"
SCHEDULER_EVENING_TIME="21:30"
SCHEDULER_WEEKLY_TIME="SUN 21:00"

# Optional overrides.
BETTER_AUTH_URL=""
NEXT_PUBLIC_BETTER_AUTH_URL=""
QQ_ALLOWED_CONTEXT_IDS=""
QQ_SCHEDULER_REPLY_WINDOW_HOURS="18"
GOAL_MATE_MODEL_PROXY=""
GOAL_MATE_MODEL_FORCE_CURL=""

# User model API keys are configured in Settings per account, not shared here.
# QQ Bot App ID and Token are configured in Settings per account, not shared here.
# Model API keys are not shared server env by default.
# For local live-quality scripts only, set one of these in your shell, not in Git:
# GOAL_MATE_LIVE_MODEL_API_KEY=""
# BAI_API_KEY=""
